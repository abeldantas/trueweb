{
  "manifest_version": 3,
  "name": "TrueWeb",
  "version": "0.1.0",
  "description": "See the web as it is. TrueWeb rewrites clickbait titles and thumbnails into honest, plain-language summaries.",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "*://*.youtube.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://openrouter.ai/*",
    "https://api.groq.com/*",
    "https://api.together.xyz/*"
  ],
  "background": { "service_worker": "background.js" },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TrueWeb",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "cycle-mode": {
      "suggested_key": { "default": "Alt+Shift+Y" },
      "description": "Toggle TrueWeb on/off for this page"
    },
    "decode-visible": {
      "suggested_key": { "default": "Alt+Shift+D" },
      "description": "Decode visible items with the LLM (honest labels)"
    }
  }
}
